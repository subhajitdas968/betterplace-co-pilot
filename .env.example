# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# --- Zendesk ---
ZD_SUBDOMAIN=betterplace1637
ZD_EMAIL=subhajit.das@betterplace.co.in
ZD_TOKEN=your-zendesk-api-token-here

# --- Anthropic (Claude API) ---
# Block #8 (MCP): set ENABLE_AI_WORKER=false to fully delegate AI insights to
# Claude Desktop via MCP. The metered worker exits cleanly when disabled.
ENABLE_AI_WORKER=false
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
MONTHLY_BUDGET_USD=20

# --- Sync ---
TARGET_GROUP_NAMES=Product Support,Managed Services
BACKFILL_DAYS=60
SYNC_INTERVAL_SECONDS=300

# --- Web app ---
APP_HOST=127.0.0.1
APP_PORT=8000
APP_PUBLIC_URL=https://BPSSTicketCoPilot.betterplace.co.in
SESSION_SECRET=generate-with-python-c-import-secrets-secrets-token-hex-32

# --- Google Workspace SSO ---
# Create OAuth 2.0 Client ID at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://BPSSTicketCoPilot.betterplace.co.in/auth/callback
# AND for local testing: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Comma-separated list of @betterplace.co.in emails allowed to sign in
